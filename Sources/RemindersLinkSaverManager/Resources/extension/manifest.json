{
  "manifest_version": 3,
  "name": "提醒事项链接收藏器",
  "description": "将当前网页保存到 macOS 提醒事项的“链接”列表，可添加备注和标签。",
  "version": "0.1.2",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "storage"
  ],
  "action": {
    "default_title": "保存到提醒事项",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "打开提醒事项链接收藏器"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
